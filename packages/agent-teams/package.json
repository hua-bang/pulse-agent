{
  "name": "pulse-coder-agent-teams",
  "version": "0.0.1-alpha.1",
  "description": "Agent teams coordination layer for Pulse Coder – multi-session collaborative agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mcp-server": {
      "import": "./dist/mcp-server.js",
      "require": "./dist/mcp-server.cjs"
    }
  },
  "bin": {
    "team-mcp-server": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pulse-coder-engine": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
